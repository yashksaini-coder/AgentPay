root = true

[*]
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{ts,tsx,js,jsx,json,css,mjs}]
indent_size = 2

[*.{yml,yaml,toml}]
indent_size = 2

[*.sol]
indent_size = 4

[*.md]
trim_trailing_whitespace = false
