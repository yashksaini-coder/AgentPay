    {"id": "title", "type": "text", "x": 320, "y": 20, "width": 460, "height": 40, "text": "IPFS Storage Flow", "fontSize": 28, "fontFamily": 2, "textAlign": "center", "strokeColor": "#0F172A", "roughness": 0},
    {"id": "subtitle", "type": "text", "x": 240, "y": 58, "width": 620, "height": 22, "text": "Content-addressed receipt pinning, broadcast, and retrieval", "fontSize": 14, "fontFamily": 2, "textAlign": "center", "strokeColor": "#64748B", "roughness": 0},

