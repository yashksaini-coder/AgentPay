    {
      "id": "cross-verify-label",
      "type": "text",
      "x": 670,
      "y": 490,
      "width": 350,
      "height": 70,
      "text": "Subscribers store receipts locally and can\ncross-verify with their own payment records.\n\nUse cases:\n• Dispute evidence (stale voucher detection)\n• Reputation auditing (payment history)\n• Network monitoring dashboard",
      "fontSize": 10,
      "fontFamily": 2,
      "textAlign": "left",
      "strokeColor": "#334155",
      "roughness": 0
    },

    {
      "id": "receipt-struct-title",
      "type": "text",
      "x": 60,
      "y": 610,
      "width": 300,
      "height": 22,
      "text": "SignedReceipt Structure",
      "fontSize": 16,
      "fontFamily": 2,
      "textAlign": "left",
      "strokeColor": "#1E293B",
      "roughness": 0
    },

    {
      "id": "struct-box",
      "type": "rectangle",
      "x": 60,
      "y": 645,
      "width": 460,
      "height": 180,
      "strokeColor": "#6366F1",
      "backgroundColor": "#EEF2FF",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "roundness": { "type": 3 }
    },
    {
      "id": "struct-code",
      "type": "text",
      "x": 80,
      "y": 655,
      "width": 420,
      "height": 160,
      "text": "@dataclass\nclass SignedReceipt:\n    receipt_id: bytes          # 16 random bytes\n    channel_id: bytes          # channel identifier\n    nonce: int                 # voucher nonce\n    amount: int                # cumulative amount (wei)\n    sender: str                # ETH address of sender\n    receiver: str              # ETH address of receiver\n    timestamp: int             # unix timestamp\n    previous_receipt_hash: bytes  # SHA-256 of prior receipt\n                                  # Genesis: 0x00 * 32\n    signature: bytes           # EIP-191 signed receipt hash",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#3730A3",
      "roughness": 0
    },

    {
      "id": "hash-calc-title",
      "type": "text",
      "x": 580,
      "y": 610,
      "width": 300,
      "height": 22,
      "text": "Hash Computation",
      "fontSize": 16,
      "fontFamily": 2,
      "textAlign": "left",
      "strokeColor": "#1E293B",
      "roughness": 0
    },

    {
      "id": "hash-calc-box",
      "type": "rectangle",
      "x": 580,
      "y": 645,
      "width": 460,
      "height": 180,
      "strokeColor": "#059669",
      "backgroundColor": "#F0FDF4",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "roughness": 0,
      "roundness": { "type": 3 }
    },
    {
      "id": "hash-calc-code",
      "type": "text",
      "x": 600,
      "y": 655,
      "width": 420,
      "height": 160,
      "text": "# Receipt hash (for chaining)\nreceipt_hash = sha256(\n    receipt_id\n    + channel_id\n    + nonce.to_bytes(8)\n    + amount.to_bytes(32)\n    + previous_receipt_hash\n    + timestamp.to_bytes(8)\n)\n\n# Signature\nsig = personal_sign(receipt_hash, sender_private_key)\n\n# Next receipt links back:\nnext_receipt.previous_receipt_hash = receipt_hash",
      "fontSize": 10,
      "fontFamily": 1,
      "textAlign": "left",
      "strokeColor": "#065F46",
      "roughness": 0
    },

